  },
  "keywords": [],
  "license": "ISC",
  "engines": {
    "node": "^24"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/PalNikolai4/barbershop_lvl-2/issues"
  },
  "homepage": "https://github.com/PalNikolai4/barbershop_lvl-2#readme",
  "devDependencies": {
    "@htmlacademy/editorconfig-cli": "^3.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "sass": "^1.99.0",
    "stylelint": "^17.10.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vite": "^8.0.10"
  },
  "version": "1.0.0",
  "dependencies": {
    "detect-libc": "^2.1.2",
